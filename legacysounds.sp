public Plugin myinfo = 
{
	name = "legacy sounds", 
	author = "may", 
	description = "i love kaworu", 
	version = PLUGIN_VERSION, 
	url = "https://github.com/lilac1337"
};

public void OnPluginStart()
{
    AddNormalSoundHook(SoundHook);
}

public void OnConfigsExecuted()
{
	for (int i; i < sizeof(g_sSounds); i++)
		AddFileToDownloadsTable(g_sSounds[i]);
}

public void OnMapStart()
{
	for (int i; i < sizeof(g_sSounds); i++)
		FakePrecacheSound(g_sSounds[i]);
}

public Action SoundHook(int clients[64], int &numClients, char sound[PLATFORM_MAX_PATH], int &entity, int &channel, float &volume, int &level, int &pitch, int &flags)
{
	if (hasOldSound(sound)) {
		Format(sound, sizeof(sound), "legacystrike/%s", sound[1]);

		EmitSoundToAll(sound, entity, channel, level, flags, volume, pitch);
		return Plugin_Stop;
	}

	PrintToConsoleAll("%b ~ %s", hasOldSound(sound), sound);

	return Plugin_Continue;
} 

bool hasOldSound(char sound[PLATFORM_MAX_PATH])
{
	Format(sound, sizeof(sound), "%s", sound[1]);

	for (int i; i < sizeof(g_sSounds); i++)
		if (StrContains(g_sSounds[i], sound, false) != -1)
			return true;

	return false;
}

void FakePrecacheSound(const char[] szPath)
{
	AddToStringTable(FindStringTable( "soundprecache" ), szPath);
}